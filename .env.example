# @bettercone/ui Development Environment
# Simple configuration for component showcase and documentation

# Basic site URL for development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Better Auth secret (only needed for auth component demos)
# BETTER_AUTH_SECRET=your_random_secret_here

# Optional: OAuth providers (only needed for auth component demos)
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret