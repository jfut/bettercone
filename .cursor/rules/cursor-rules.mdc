### Convex Schema

```typescript
// In packages/convex/convex/schema.ts
yourTable: defineTable({
  organizationId: v.id("organizations"),
  name: v.string(),
  createdAt: v.number(),
  createdBy: v.id("users"),
})
.index("by_organization", ["organizationId"])
.index("by_user", ["createdBy"])
```

### Convex Queries

```typescript
// In packages/convex/convex/yourFeature.ts
import { query, mutation } from "./_generated/server";
import { v } from "convex/values";

export const list = query({
  args: { organizationId: v.id("organizations") },
  handler: async (ctx, args) => {
    // 1. Get user ID
    const userId = await getUserId(ctx);
    if (!userId) throw new Error("Unauthorized");
    
    // 2. Check membership
    const member = await ctx.db
      .query("organizationMembers")
      .withIndex("by_organization_user", (q) =>
        q.eq("organizationId", args.organizationId)
         .eq("userId", userId)
      )
      .first();
    
    if (!member) throw new Error("Not a member");
    
    // 3. Query data
    return await ctx.db
      .query("yourTable")
      .withIndex("by_organization", (q) => 
        q.eq("organizationId", args.organizationId)
      )
      .collect();
  },
});
```

### Convex Mutations

```typescript
export const create = mutation({
  args: { 
    organizationId: v.id("organizations"),
    name: v.string(),
  },
  handler: async (ctx, args) => {
    // 1. Get user ID
    const userId = await getUserId(ctx);
    if (!userId) throw new Error("Unauthorized");
    
    // 2. Check permissions (owner/admin only)
    const member = await ctx.db
      .query("organizationMembers")
      .withIndex("by_organization_user", (q) =>
        q.eq("organizationId", args.organizationId)
         .eq("userId", userId)
      )
      .first();
    
    if (!member) throw new Error("Not a member");
    if (member.role !== "owner" && member.role !== "admin") {
      throw new Error("No permission");
    }
    
    // 3. Create
    return await ctx.db.insert("yourTable", {
      organizationId: args.organizationId,
      name: args.name,
      createdAt: Date.now(),
      createdBy: userId,
    });
  },
});
```

### Frontend Pages

```typescript
// apps/web/src/app/demo/your-feature/page.tsx
"use client";

import { useQuery, useMutation } from "convex/react";
import { api } from "@repo/convex";
import { useOrganization } from "@/hooks/use-organization";
import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";

export default function YourFeaturePage() {
  const { currentOrganization } = useOrganization();
  
  const items = useQuery(
    api.yourFeature.list,
    currentOrganization?.id 
      ? { organizationId: currentOrganization.id }
      : "skip"
  );
  
  const createItem = useMutation(api.yourFeature.create);
  
  if (!currentOrganization) return <div>Select organization</div>;
  if (!items) return <div>Loading...</div>;
  
  return (
    <div className="space-y-4">
      <h1 className="text-3xl font-bold">Your Feature</h1>
      {items.map((item) => (
        <Card key={item._id}>{item.name}</Card>
      ))}
      <Button onClick={() => createItem({ 
        organizationId: currentOrganization.id,
        name: "New Item" 
      })}>
        Add Item
      </Button>
    </div>
  );
}
```

### Forms

```typescript
// Use react-hook-form + zod
import { useForm } from "react-hook-form";
import { zodResolver } from "@hookform/resolvers/zod";
import { z } from "zod";
import { Form, FormField, FormItem, FormLabel, FormControl } from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import { Button } from "@/components/ui/button";

const schema = z.object({
  name: z.string().min(1, "Name required"),
  description: z.string().optional(),
});

export function YourForm() {
  const form = useForm({
    resolver: zodResolver(schema),
    defaultValues: { name: "", description: "" },
  });
  
  const createItem = useMutation(api.yourFeature.create);
  
  const onSubmit = async (values: z.infer<typeof schema>) => {
    await createItem({ ...values, organizationId: currentOrganization.id });
  };
  
  return (
    <Form {...form}>
      <form onSubmit={form.handleSubmit(onSubmit)} className="space-y-4">
        <FormField
          control={form.control}
          name="name"
          render={({ field }) => (
            <FormItem>
              <FormLabel>Name</FormLabel>
              <FormControl>
                <Input {...field} />
              </FormControl>
            </FormItem>
          )}
        />
        <Button type="submit">Create</Button>
      </form>
    </Form>
  );
}
```

