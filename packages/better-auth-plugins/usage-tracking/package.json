{
  "name": "@bettercone/better-auth-plugin-usage-tracking",
  "version": "0.1.0",
  "description": "Usage tracking plugin for Better Auth with organization-level limits",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "peerDependencies": {
    "better-auth": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "nanostores": "^1.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.10.0",
    "@types/react": "^18.3.12",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
